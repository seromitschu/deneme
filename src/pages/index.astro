---
// src/pages/index.astro
export const prerender = false;

const name = import.meta.env.PUBLIC_NAME;

const LASTFM_API_KEY = import.meta.env.PUBLIC_LASTFM_API_KEY;
const LASTFM_USERNAME = import.meta.env.PUBLIC_LASTFM_USERNAME;
const SPOTIFY_CLIENT_ID = import.meta.env.SPOTIFY_CLIENT_ID;
const SPOTIFY_CLIENT_SECRET = import.meta.env.SPOTIFY_CLIENT_SECRET;

const LINK_GITHUB = import.meta.env.LINK_GITHUB;
const LINK_SPOTIFY = import.meta.env.LINK_SPOTIFY;
const LINK_LINKEDIN = import.meta.env.LINK_LINKEDIN;
const LINK_DISCORD = import.meta.env.LINK_DISCORD;

const urlObj = new URL(Astro.request.url);
const searchQ = urlObj.searchParams.get('q');
const searchArtist = urlObj.searchParams.get('artist');
const searchType = urlObj.searchParams.get('type') || 'track';

if (searchQ) {
  try {
    const tokenRes = await fetch('https://accounts.spotify.com/api/token', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded',
        'Authorization': 'Basic ' + btoa(SPOTIFY_CLIENT_ID + ':' + SPOTIFY_CLIENT_SECRET)
      },
      body: 'grant_type=client_credentials'
    });
    const tokenData = await tokenRes.json();
    const accessToken = tokenData.access_token;

    let spotifyQuery = '';
    if (searchType === 'track' && searchArtist) {
      spotifyQuery = `track:${searchQ} artist:${searchArtist}`;
    } else if (searchType === 'album' && searchArtist) {
      spotifyQuery = `album:${searchQ} artist:${searchArtist}`;
    } else {
      spotifyQuery = `artist:${searchQ}`;
    }

    const searchRes = await fetch(`https://api.spotify.com/v1/search?q=${encodeURIComponent(spotifyQuery)}&type=${searchType === 'album' ? 'album' : searchType}&limit=1`, {
      headers: { 'Authorization': `Bearer ${accessToken}` }
    });
    const searchData = await searchRes.json();
    let imageUrl = null;

    if (searchType === 'artist' && searchData.artists?.items?.[0]?.images?.[0]) {
      imageUrl = searchData.artists.items[0].images[0].url;
    } else if (searchType === 'track' && searchData.tracks?.items?.[0]?.album?.images?.[0]) {
      imageUrl = searchData.tracks.items[0].album.images[0].url;
    } else if (searchType === 'album' && searchData.albums?.items?.[0]?.images?.[0]) {
      imageUrl = searchData.albums.items[0].images[0].url;
    }

    return new Response(JSON.stringify({ url: imageUrl }), {
      status: 200,
      headers: { "Content-Type": "application/json" }
    });
  } catch (e) {
    const errorMsg = e instanceof Error ? e.message : 'Unknown error';
    return new Response(JSON.stringify({ error: errorMsg }), { status: 500 });
  }
}
---
<!doctype html>
<html lang="tr">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
        <title>{name}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">
    </head>
    <body>

        <div id="ambient-glow" class="ambient-glow"></div>

        <div id="app-content">
            <main class="minimal-container">
                
                <section class="intro-section">
                    <h1 class="welcome-text">
                        <span class="word delay-1">Merhaba<span class="wave-emoji">👋</span></span> <br />
                        <span class="word delay-2">Ben <span class="word delay-2 name">{name}</span>.</span> <br />
                        <span class="word delay-3 muted-text">Dijital deneyimler</span> <br />
                        <span class="word delay-4 muted-text">tasarlayan ve geliştiren</span> <br />
                        <span class="word delay-5 muted-text">bir arayüz geliştirici.</span>
                    </h1>
                </section>

                <section class="about-section word delay-6">
                    <h2 class="section-title">Hakkımda</h2>
                    <div class="about-content">
                        <p>
                            Tasarım ve kodun kesiştiği noktada, insanı yormayan temiz arayüzler üretmeye odaklanıyorum. Gereksiz tüm süslemelerden arındırılmış, işlevsel ve performanslı web deneyimleri geliştirmek en büyük motivasyonum.
                        </p>
                    </div>
                </section>

                <section class="experience-section word delay-7">
                    <div class="experience-grid">
                        
                        <div class="exp-card liquid-glass-effect">
                            <h3 class="exp-card-title">Deneyim</h3>
                            <div class="exp-timeline">
                                <div class="timeline-item">

                                    <div class="timeline-info">
                                        <span class="timeline-date">2025 — Günümüz</span>
                                        <span class="timeline-role">Founder</span>
                                        <span class="timeline-company">Ai-Toyon Game Studio</span>
                                    </div>
                                </div>
                                <div class="timeline-item">

                                    <div class="timeline-info">
                                        <span class="timeline-date">2023 — Günümüz</span>
                                        <span class="timeline-role">Full Stack Developer</span>
                                        <span class="timeline-company">mitschu.co</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="exp-card liquid-glass-effect">
                            <h3 class="exp-card-title">Eğitim</h3>
                            <div class="exp-timeline">
                                <div class="timeline-item">
                                    <div class="timeline-logo">
                                        <img src="/logos/ssbl.jpg" alt="Samsun SBL Logo" onerror="this.style.display='none'" />
                                    </div>
                                    <div class="timeline-info">
                                        <span class="timeline-date">2020 — 2025</span>
                                        <span class="timeline-role">İbrahim Tanrıverdi Sosyal Bilimler Lisesi</span>
                                        <span class="timeline-company">Mezuniyet</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </section>

                <section class="music-section word delay-8">
                    
                    <div class="music-header-block">
                        <div class="title-area">
                            <h2 class="section-title">Müzik Odası</h2>
                            <div class="period-switcher liquid-glass-effect">
                                <button class="period-btn active" data-period="7day">Haftalık</button>
                                <button class="period-btn" data-period="1month">Aylık</button>
                                <button class="period-btn" data-period="12month">Yıllık</button>
                                <button class="period-btn" data-period="overall">Genel</button>
                            </div>
                        </div>

                        <a id="live-track-link" href="#" target="_blank" class="current-track-card-link">
                            <div class="current-track-card liquid-glass-effect">
                                <div class="img-wrapper-live">
                                    <img id="live-track-img" src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" alt="Albüm Kapağı" class="current-track-img" />
                                </div>
                                <div class="current-track-details">
                                    <div class="music-status">
                                        <div id="audio-visualizer" class="audio-visualizer">
                                            <span></span><span></span><span></span>
                                        </div>
                                        <span id="live-status-text">YÜKLENİYOR...</span>
                                    </div>
                                    <div class="music-info">
                                        <span class="track-title" id="live-track-title">-</span>
                                        <span class="track-separator">—</span>
                                        <span class="track-artist" id="live-track-artist">-</span>
                                    </div>
                                    <div class="music-album">
                                        <span class="album-title" id="live-track-album">-</span>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>

                    <div class="sub-music-block">
                        <h3 class="subsection-title">En Çok Dinlediğim Şarkılar</h3>
                        <div class="bento-seamless-grid" id="top-tracks-grid"></div>
                    </div>

                    <div class="sub-music-block">
                        <h3 class="subsection-title">En Çok Dinlediğim Sanatçılar</h3>
                        <div class="bento-seamless-grid" id="top-artists-grid"></div>
                    </div>

                    <div class="sub-music-block">
                        <h3 class="subsection-title">En Çok Dinlediğim Albümler</h3>
                        <div class="bento-seamless-grid" id="top-albums-grid"></div>
                    </div>

                </section>

                <footer class="site-footer word delay-8">
                    <div class="footer-divider"></div>
                    <div class="footer-content">
                        <div class="footer-credits">
                            made with <span class="animated-heart">❤️</span> by {name}
                        </div>
                        <div class="footer-links">
                            <a href={`${LINK_SPOTIFY}`} target="_blank" class="footer-link-item">Spotify</a>
                            <a href={`${LINK_DISCORD}`} target="_blank" class="footer-link-item">Discord</a>
                            <a href={`${LINK_GITHUB}`} target="_blank" class="footer-link-item">GitHub</a>
                            <a href={`${LINK_LINKEDIN}`} target="_blank" class="footer-link-item">LinkedIn</a>
                        </div>
                    </div>
                </footer>

            </main>
        </div>

        <script define:vars={{ LASTFM_API_KEY, LASTFM_USERNAME }}>
            let currentPeriod = '7day';
            let imageObserver;

            function initLazyLoading() {
                if (imageObserver) imageObserver.disconnect();
                imageObserver = new IntersectionObserver((entries, observer) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            const node = entry.target;
                            const { query, artist, imgid, type } = node.dataset;
                            executeSpotifyCoverFetch(query, artist, imgid, type);
                            observer.unobserve(node);
                        }
                    });
                }, { rootMargin: '200px' });
            }

            async function executeSpotifyCoverFetch(searchQuery, artistName, imgElementId, type) {
                try {
                    let endpoint = `?q=${encodeURIComponent(searchQuery)}&type=${type}`;
                    if (artistName && artistName !== 'null') {
                        endpoint += `&artist=${encodeURIComponent(artistName)}`;
                    }

                    const res = await fetch(endpoint);
                    if (res.ok) {
                        const data = await res.json();
                        if (data.url) {
                            const img = document.getElementById(imgElementId);
                            if (img) {
                                img.src = data.url;
                                if (imgElementId === 'live-track-img') {
                                    updateAmbientGlow(data.url);
                                }
                            }
                            return;
                        }
                    }
                } catch (e) { console.error("Görsel hatası:", e); }
            }

            function updateAmbientGlow(url) {
                if (window.innerWidth <= 768) return;
                const glow = document.getElementById('ambient-glow');
                if (glow) {
                    glow.style.backgroundImage = `url('${url}')`;
                    glow.style.opacity = '0.12';
                }
            }

            function fetchSpotifyCover(searchQuery, artistName, imgElementId, type = 'track') {
                const imgElement = document.getElementById(imgElementId);
                if (!imgElement) return;

                const parentNode = imgElement.closest('.bento-node');
                if (parentNode) {
                    parentNode.dataset.query = searchQuery;
                    parentNode.dataset.artist = artistName;
                    parentNode.dataset.imgid = imgElementId;
                    parentNode.dataset.type = type;
                    imageObserver.observe(parentNode);
                } else {
                    executeSpotifyCoverFetch(searchQuery, artistName, imgElementId, type);
                }
            }

            function calculateMinutes(playcount) {
                const count = parseInt(playcount, 10) || 0;
                return Math.round(count * 3.5);
            }

            function formatPlaycount(playcount) {
                const count = parseInt(playcount, 10) || 0;
                return `${count} kez`;
            }

            function initLiquidGlassTracking() {
                if (window.innerWidth <= 768) return;
                const cards = document.querySelectorAll('.liquid-glass-effect, .bento-node');
                cards.forEach(card => {
                    card.removeAttribute('style');
                    card.addEventListener('mousemove', (e) => {
                        const rect = card.getBoundingClientRect();
                        const x = e.clientX - rect.left;
                        const y = e.clientY - rect.top;
                        card.style.setProperty('--mouse-x', `${x}px`);
                        card.style.setProperty('--mouse-y', `${y}px`);
                    });
                });
            }

            async function fetchLiveTrack() {
                try {
                    const trackRes = await fetch(`https://ws.audioscrobbler.com/2.0/?method=user.getrecenttracks&user=${LASTFM_USERNAME}&api_key=${LASTFM_API_KEY}&format=json&limit=1`);
                    if (trackRes.ok) {
                        const trackData = await trackRes.json();
                        const track = trackData.recenttracks?.track?.[0];
                        
                        if (track) {
                            const isPlaying = track['@attr'] && track['@attr'].nowplaying === 'true';
                            const artistName = track.artist?.['#text'] || '';
                            const trackName = track.name || '';

                            document.getElementById('live-track-title').textContent = trackName;
                            document.getElementById('live-track-artist').textContent = artistName;
                            document.getElementById('live-track-album').textContent = track.album?.['#text'] || 'Single';
                            document.getElementById('live-track-link').href = track.url || '#';
                            
                            fetchSpotifyCover(trackName, artistName, 'live-track-img', 'track');
                            
                            const visualizer = document.getElementById('audio-visualizer');
                            const txt = document.getElementById('live-status-text');
                            if (isPlaying) {
                                visualizer.classList.add('playing');
                                txt.textContent = "ŞU AN DİNLENİYOR";
                                txt.style.color = "#30d158";
                            } else {
                                visualizer.classList.remove('playing');
                                txt.textContent = "SON DİNLENEN";
                                txt.style.color = "#48484a";
                            }
                        }
                    }
                } catch (e) { console.error("Canlı veri hatası:", e); }
            }

            async function fetchTopStats(period) {
                try {
                    initLazyLoading();
                    const defaultTrackImg = "https://images.unsplash.com/photo-1511671782779-c97d3d27a1d4?w=400&auto=format&fit=crop&q=60";
                    const defaultArtistImg = "https://images.unsplash.com/photo-1501386761578-eac5c94b800a?w=400&auto=format&fit=crop&q=60";

                    // 1. ŞARKILAR
                    const topTracksRes = await fetch(`https://ws.audioscrobbler.com/2.0/?method=user.gettoptracks&user=${LASTFM_USERNAME}&api_key=${LASTFM_API_KEY}&period=${period}&format=json&limit=5`);
                    const grid = document.getElementById('top-tracks-grid');
                    if (topTracksRes.ok && grid) {
                        const topTracksData = await topTracksRes.json();
                        const topTracks = topTracksData.toptracks?.track || [];
                        
                        let htmlContent = '';
                        topTracks.forEach((item, index) => {
                            const artistName = item.artist?.name || '';
                            const trackName = item.name || '';
                            const playcountText = formatPlaycount(item.playcount);
                            const imgId = `track-img-${index}`;
                            
                            htmlContent += `
                                <a href="${item.url}" target="_blank" class="bento-node ${index === 0 ? 'bento-big' : ''}" title="${trackName}">
                                    <div class="bento-rank">#${index + 1}</div>
                                    <img id="${imgId}" src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" onerror="this.src='${defaultTrackImg}'" alt="${trackName}" class="bento-img"/>
                                    <div class="bento-overlay">
                                        <div class="bento-meta">
                                            <span class="bento-title">${trackName}</span>
                                            <span class="bento-artist">${artistName}</span>
                                            <span class="bento-sub">${playcountText} dinlendi</span>
                                        </div>
                                    </div>
                                </a>
                            `;
                        });
                        grid.innerHTML = htmlContent;
                        topTracks.forEach((item, index) => {
                            fetchSpotifyCover(item.name || '', item.artist?.name || '', `track-img-${index}`, 'track');
                        });
                    }

                    // 2. SANATÇILAR
                    const topArtistsRes = await fetch(`https://ws.audioscrobbler.com/2.0/?method=user.gettopartists&user=${LASTFM_USERNAME}&api_key=${LASTFM_API_KEY}&period=${period}&format=json&limit=5`);
                    const artistGrid = document.getElementById('top-artists-grid');
                    if (topArtistsRes.ok && artistGrid) {
                        const topArtistsData = await topArtistsRes.json();
                        const topArtists = topArtistsData.topartists?.artist || [];
                        
                        let htmlContent = '';
                        topArtists.forEach((artist, index) => {
                            const artistName = artist.name || '';
                            const playcountText = formatPlaycount(artist.playcount);
                            const imgId = `artist-img-${index}`;

                            htmlContent += `
                                <a href="${artist.url}" target="_blank" class="bento-node ${index === 0 ? 'bento-big' : ''}" title="${artistName}">
                                    <div class="bento-rank">#${index + 1}</div>
                                    <img id="${imgId}" src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" onerror="this.src='${defaultArtistImg}'" alt="${artistName}" class="bento-img" />
                                    <div class="bento-overlay">
                                        <div class="bento-meta">
                                            <span class="bento-title">${artistName}</span>
                                            <span class="bento-sub">${playcountText} dinlendi</span>
                                        </div>
                                    </div>
                                </a>
                            `;
                        });
                        artistGrid.innerHTML = htmlContent;
                        topArtists.forEach((artist, index) => {
                            fetchSpotifyCover(artist.name || '', null, `artist-img-${index}`, 'artist');
                        });
                    }

                    // 3. ALBÜMLER
                    const topAlbumsRes = await fetch(`https://ws.audioscrobbler.com/2.0/?method=user.gettopalbums&user=${LASTFM_USERNAME}&api_key=${LASTFM_API_KEY}&period=${period}&format=json&limit=5`);
                    const albumStrip = document.getElementById('top-albums-grid');
                    if (topAlbumsRes.ok && albumStrip) {
                        const topAlbumsData = await topAlbumsRes.json();
                        const topAlbums = topAlbumsData.topalbums?.album || [];
                        
                        let htmlContent = '';
                        topAlbums.forEach((album, index) => {
                            const artistName = album.artist?.name || '';
                            const albumName = album.name || '';
                            const playcountText = formatPlaycount(album.playcount);
                            const imgId = `album-img-${index}`;

                            htmlContent += `
                                <a href="${album.url}" target="_blank" class="bento-node ${index === 0 ? 'bento-big' : ''}" title="${albumName} — ${artistName}">
                                    <div class="bento-rank">#${index + 1}</div>
                                    <img id="${imgId}" src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" onerror="this.src='${defaultTrackImg}'" alt="${albumName}" class="bento-img" />
                                    <div class="bento-overlay">
                                        <div class="bento-meta">
                                            <span class="bento-title">${albumName}</span>
                                            <span class="bento-artist">${artistName}</span>
                                            <span class="bento-sub">${playcountText} dinlendi</span>
                                        </div>
                                    </div>
                                </a>
                            `;
                        });
                        albumStrip.innerHTML = htmlContent;
                        topAlbums.forEach((album, index) => {
                            fetchSpotifyCover(album.name || '', album.artist?.name || '', `album-img-${index}`, 'album');
                        });
                    }

                    initLiquidGlassTracking();
                } catch (error) { console.error("İstatistik hatası:", error); }
            }

            function setupPeriodControls() {
                const buttons = document.querySelectorAll('.period-btn');
                buttons.forEach(btn => {
                    btn.addEventListener('click', () => {
                        buttons.forEach(b => b.classList.remove('active'));
                        btn.classList.add('active');
                        currentPeriod = btn.getAttribute('data-period');
                        fetchTopStats(currentPeriod);
                    });
                });
            }

            window.addEventListener('load', () => {
                const content = document.getElementById('app-content');
                if (content) content.classList.add('start-sequence');
                
                fetchLiveTrack();
                fetchTopStats(currentPeriod);
                setupPeriodControls();
                setInterval(fetchLiveTrack, 15000);
            });

// Pop-up'ı sayfa yüklendikten sonra sadece görünür yapıyoruz
    window.addEventListener('load', () => {
        const popup = document.getElementById('visitor-popup');
        if (popup) {
            setTimeout(() => {
                popup.classList.add('visible');
            }, 800);
        }
    });
        </script>
<div id="visitor-popup" class="visitor-popup">
    <div class="visitor-content">
        <span class="visitor-label">Ziyaretçi</span>
        <img 
            src="https://api.visitorbadge.io/api/combined?path=benimsitem&countColor=%23ffffff" 
            alt="Ziyaretçi Sayacı"
            class="visitor-value-img"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='block';"
        />
        <span class="visitor-fallback" style="display: none; font-family: monospace; font-size: 0.9rem;">--</span>
    </div>
</div>
    
    </body>
</html>

<style is:global>
    ::selection {
        background-color: white;
        color: black;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
        background-color: #030303;
        color: #f5f5f7;
        font-family: 'Inter', -apple-system, sans-serif;
        -webkit-font-smoothing: antialiased;
        height: 100%;
        scrollbar-width: none;
        position: relative;
    }
    html::-webkit-scrollbar, body::-webkit-scrollbar { display: none; }

    .ambient-glow {
        position: fixed;
        top: 35%;
        right: -10%;
        width: 600px;
        height: 600px;
        background-size: cover;
        background-position: center;
        filter: blur(140px);
        opacity: 0;
        z-index: 0;
        pointer-events: none;
        transition: background-image 1.2s ease, opacity 1.2s ease;
        border-radius: 50%;
    }

    #app-content { min-height: 100%; display: flex; align-items: center; justify-content: center; position: relative; z-index: 1; }

    .word {
        display: inline-block;
        opacity: 0;
        filter: blur(10px);
        transform: translateY(8px);
        transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), filter 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .name {
        color: rgb(255, 50, 50);
    }
    .start-sequence .word { opacity: 1; filter: blur(0px); transform: translateY(0); }
    .delay-1 { transition-delay: 0.04s; }
    .delay-2 { transition-delay: 0.10s; }
    .delay-3 { transition-delay: 0.16s; }
    .delay-4 { transition-delay: 0.22s; }
    .delay-5 { transition-delay: 0.28s; }
    .delay-6 { transition-delay: 0.38s; }
    .delay-7 { transition-delay: 0.48s; }
    .delay-8 { transition-delay: 0.58s; }

    .wave-emoji {
        display: inline-block;
        margin-left: 0.4rem;
        transform-origin: 75% 75%;
        opacity: 0;
        filter: blur(4px);
        transition: opacity 0.5s ease 0.12s;
    }
    .start-sequence .wave-emoji { opacity: 1; filter: blur(0px); animation: wave-animation 1.2s ease-in-out infinite alternate; }
    @keyframes wave-animation { 0%, 100%, 60% { transform: rotate(0deg); } 10%, 30% { transform: rotate(12deg); } 20% { transform: rotate(-5deg); } 40% { transform: rotate(-2deg); } 50% { transform: rotate(8deg); } }

    .minimal-container {
        max-width: 840px;
        width: 100%;
        margin: 0 auto;
        padding: clamp(4rem, 10vw, 7rem) clamp(1.2rem, 5vw, 1.5rem);
        display: flex;
        flex-direction: column;
        gap: clamp(3.5rem, 8vw, 6rem);
    }

    .welcome-text { 
        font-family: 'Inter', sans-serif;
        font-weight: 700;
