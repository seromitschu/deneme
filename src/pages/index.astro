<section class="guestbook-section word delay-8">
    <h2 class="section-title">Ziyaretçi Defteri</h2>
    
    <div class="guestbook-block">
        <form id="guestbook-form" class="guestbook-form liquid-glass-effect">
            <div class="form-inputs">
                <input type="text" id="guest-name" placeholder="İsim" required autocomplete="off" maxlength="30" class="guest-input"/>
                <input type="text" id="guest-message" placeholder="Not bırak..." required autocomplete="off" maxlength="150" class="guest-input message-input"/>
            </div>
            <button type="submit" class="guest-submit-btn">Gönder</button>
        </form>

        <div class="messages-wrapper">
            <div id="guestbook-messages" class="guestbook-messages">
                </div>
            
            <div class="messages-nav">
                <button id="prev-messages" class="nav-btn" disabled>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                </button>
                <span id="page-info" class="page-info">1 / 1</span>
                <button id="next-messages" class="nav-btn" disabled>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </button>
            </div>
        </div>
    </div>
</section>

                <footer class="site-footer word delay-8">
                    <div class="footer-divider"></div>
                    <div class="footer-content">
                        <div class="footer-credits">
                            made with <span class="animated-heart">❤️</span> by {name}
                        </div>
                        <div class="footer-links">
                            <a href={`${LINK_SPOTIFY}`} target="_blank" class="footer-link-item">Spotify</a>
                            <a href={`${LINK_DISCORD}`} target="_blank" class="footer-link-item">Discord</a>
                            <a href={`${LINK_GITHUB}`} target="_blank" class="footer-link-item">GitHub</a>
                            <a href={`${LINK_LINKEDIN}`} target="_blank" class="footer-link-item">LinkedIn</a>
                        </div>
                    </div>
                </footer>

            </main>
        </div>

        <script define:vars={{ LASTFM_API_KEY, LASTFM_USERNAME }}>
            let currentPeriod = '7day';
            let imageObserver;

            function initLazyLoading() {
                if (imageObserver) imageObserver.disconnect();
                imageObserver = new IntersectionObserver((entries, observer) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            const node = entry.target;
                            const { query, artist, imgid, type } = node.dataset;
                            executeSpotifyCoverFetch(query, artist, imgid, type);
                            observer.unobserve(node);
                        }
                    });
                }, { rootMargin: '200px' });
            }

            async function executeSpotifyCoverFetch(searchQuery, artistName, imgElementId, type) {
                try {
                    let endpoint = `?q=${encodeURIComponent(searchQuery)}&type=${type}`;
                    if (artistName && artistName !== 'null') {
                        endpoint += `&artist=${encodeURIComponent(artistName)}`;
                    }

                    const res = await fetch(endpoint);
                    if (res.ok) {
                        const data = await res.json();
                        if (data.url) {
                            const img = document.getElementById(imgElementId);
                            if (img) {
                                img.src = data.url;
                                if (imgElementId === 'live-track-img') {
                                    updateAmbientGlow(data.url);
                                }
                            }
                            return;
                        }
                    }
                } catch (e) { console.error("Görsel hatası:", e); }
            }

            // Arka Plan Canlı Parlama Kontrolü
            function updateAmbientGlow(url) {
                if (window.innerWidth <= 768) return;
                const glow = document.getElementById('ambient-glow');
                if (glow) {
                    glow.style.backgroundImage = `url('${url}')`;
                    glow.style.opacity = '0.12';
                }
            }

            function fetchSpotifyCover(searchQuery, artistName, imgElementId, type = 'track') {
                const imgElement = document.getElementById(imgElementId);
                if (!imgElement) return;

                const parentNode = imgElement.closest('.bento-node');
                if (parentNode) {
                    parentNode.dataset.query = searchQuery;
                    parentNode.dataset.artist = artistName;
                    parentNode.dataset.imgid = imgElementId;
                    parentNode.dataset.type = type;
                    imageObserver.observe(parentNode);
                } else {
                    executeSpotifyCoverFetch(searchQuery, artistName, imgElementId, type);
                }
            }

            function calculateMinutes(playcount) {
                const count = parseInt(playcount, 10) || 0;
                return Math.round(count * 3.5);
            }

            function formatPlaycount(playcount) {
                const count = parseInt(playcount, 10) || 0;
                return `${count} kez`;
            }

            function initLiquidGlassTracking() {
                if (window.innerWidth <= 768) return;
                const cards = document.querySelectorAll('.liquid-glass-effect, .bento-node');
                cards.forEach(card => {
                    card.removeAttribute('style');
                    card.addEventListener('mousemove', (e) => {
                        const rect = card.getBoundingClientRect();
                        const x = e.clientX - rect.left;
                        const y = e.clientY - rect.top;
                        card.style.setProperty('--mouse-x', `${x}px`);
                        card.style.setProperty('--mouse-y', `${y}px`);
                    });
                });
            }

            async function fetchLiveTrack() {
                try {
                    const trackRes = await fetch(`https://ws.audioscrobbler.com/2.0/?method=user.getrecenttracks&user=${LASTFM_USERNAME}&api_key=${LASTFM_API_KEY}&format=json&limit=1`);
                    if (trackRes.ok) {
                        const trackData = await trackRes.json();
                        const track = trackData.recenttracks?.track?.[0];
                        
                        if (track) {
                            const isPlaying = track['@attr'] && track['@attr'].nowplaying === 'true';
                            const artistName = track.artist?.['#text'] || '';
                            const trackName = track.name || '';

                            document.getElementById('live-track-title').textContent = trackName;
                            document.getElementById('live-track-artist').textContent = artistName;
                            document.getElementById('live-track-album').textContent = track.album?.['#text'] || 'Single';
                            document.getElementById('live-track-link').href = track.url || '#';
                            
                            fetchSpotifyCover(trackName, artistName, 'live-track-img', 'track');
                            
                            const visualizer = document.getElementById('audio-visualizer');
                            const txt = document.getElementById('live-status-text');
                            if (isPlaying) {
                                visualizer.classList.add('playing');
                                txt.textContent = "ŞU AN DİNLENİYOR";
                                txt.style.color = "#30d158";
                            } else {
                                visualizer.classList.remove('playing');
                                txt.textContent = "SON DİNLENEN";
                                txt.style.color = "#48484a";
                            }
                        }
                    }
                } catch (e) { console.error("Canlı veri hatası:", e); }
            }

            async function fetchTopStats(period) {
                try {
                    initLazyLoading();
                    const defaultTrackImg = "https://images.unsplash.com/photo-1511671782779-c97d3d27a1d4?w=400&auto=format&fit=crop&q=60";
                    const defaultArtistImg = "https://images.unsplash.com/photo-1501386761578-eac5c94b800a?w=400&auto=format&fit=crop&q=60";

                    // 1. ŞARKILAR
                    const topTracksRes = await fetch(`https://ws.audioscrobbler.com/2.0/?method=user.gettoptracks&user=${LASTFM_USERNAME}&api_key=${LASTFM_API_KEY}&period=${period}&format=json&limit=5`);
                    const grid = document.getElementById('top-tracks-grid');
                    if (topTracksRes.ok && grid) {
                        const topTracksData = await topTracksRes.json();
                        const topTracks = topTracksData.toptracks?.track || [];
                        
                        let htmlContent = '';
                        topTracks.forEach((item, index) => {
                            const artistName = item.artist?.name || '';
                            const trackName = item.name || '';
                            const playcountText = formatPlaycount(item.playcount);
                            const imgId = `track-img-${index}`;
                            
                            htmlContent += `
                                <a href="${item.url}" target="_blank" class="bento-node ${index === 0 ? 'bento-big' : ''}" title="${trackName}">
                                    <div class="bento-rank">#${index + 1}</div>
                                    <img id="${imgId}" src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" onerror="this.src='${defaultTrackImg}'" alt="${trackName}" class="bento-img"/>
                                    <div class="bento-overlay">
                                        <div class="bento-meta">
                                            <span class="bento-title">${trackName}</span>
                                            <span class="bento-artist">${artistName}</span>
                                            <span class="bento-sub">${playcountText} dinlendi</span>
                                        </div>
                                    </div>
                                </a>
                            `;
                        });
                        grid.innerHTML = htmlContent;
                        topTracks.forEach((item, index) => {
                            fetchSpotifyCover(item.name || '', item.artist?.name || '', `track-img-${index}`, 'track');
                        });
                    }

                    // 2. SANATÇILAR
                    const topArtistsRes = await fetch(`https://ws.audioscrobbler.com/2.0/?method=user.gettopartists&user=${LASTFM_USERNAME}&api_key=${LASTFM_API_KEY}&period=${period}&format=json&limit=5`);
                    const artistGrid = document.getElementById('top-artists-grid');
                    if (topArtistsRes.ok && artistGrid) {
                        const topArtistsData = await topArtistsRes.json();
                        const topArtists = topArtistsData.topartists?.artist || [];
                        
                        let htmlContent = '';
                        topArtists.forEach((artist, index) => {
                            const artistName = artist.name || '';
                            const minutes = calculateMinutes(artist.playcount);
                            const imgId = `artist-img-${index}`;

                            htmlContent += `
                                <a href="${artist.url}" target="_blank" class="bento-node ${index === 0 ? 'bento-big' : ''}" title="${artistName}">
                                    <div class="bento-rank">#${index + 1}</div>
                                    <img id="${imgId}" src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" onerror="this.src='${defaultArtistImg}'" alt="${artistName}" class="bento-img" />
                                    <div class="bento-overlay">
                                        <div class="bento-meta">
                                            <span class="bento-title">${artistName}</span>
                                            <span class="bento-sub">${minutes} dk dinleme</span>
                                        </div>
                                    </div>
                                </a>
                            `;
                        });
                        artistGrid.innerHTML = htmlContent;
                        topArtists.forEach((artist, index) => {
                            fetchSpotifyCover(artist.name || '', null, `artist-img-${index}`, 'artist');
                        });
                    }

                    // 3. ALBÜMLER
                    const topAlbumsRes = await fetch(`https://ws.audioscrobbler.com/2.0/?method=user.gettopalbums&user=${LASTFM_USERNAME}&api_key=${LASTFM_API_KEY}&period=${period}&format=json&limit=5`);
                    const albumStrip = document.getElementById('top-albums-grid');
                    if (topAlbumsRes.ok && albumStrip) {
                        const topAlbumsData = await topAlbumsRes.json();
                        const topAlbums = topAlbumsData.topalbums?.album || [];
                        
                        let htmlContent = '';
                        topAlbums.forEach((album, index) => {
                            const artistName = album.artist?.name || '';
                            const albumName = album.name || '';
                            const minutes = calculateMinutes(album.playcount);
                            const imgId = `album-img-${index}`;

                            htmlContent += `
                                <a href="${album.url}" target="_blank" class="bento-node ${index === 0 ? 'bento-big' : ''}" title="${albumName} — ${artistName}">
                                    <div class="bento-rank">#${index + 1}</div>
                                    <img id="${imgId}" src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" onerror="this.src='${defaultTrackImg}'" alt="${albumName}" class="bento-img" />
                                    <div class="bento-overlay">
                                        <div class="bento-meta">
                                            <span class="bento-title">${albumName}</span>
                                            <span class="bento-artist">${artistName}</span>
                                            <span class="bento-sub">${minutes} dk dinleme</span>
                                        </div>
                                    </div>
                                </a>
                            `;
                        });
                        albumStrip.innerHTML = htmlContent;
                        topAlbums.forEach((album, index) => {
                            fetchSpotifyCover(album.name || '', album.artist?.name || '', `album-img-${index}`, 'album');
                        });
                    }

                    initLiquidGlassTracking();
                } catch (error) { console.error("İstatistik hatası:", error); }
            }

            function setupPeriodControls() {
                const buttons = document.querySelectorAll('.period-btn');
                buttons.forEach(btn => {
                    btn.addEventListener('click', () => {
                        buttons.forEach(b => b.classList.remove('active'));
                        btn.classList.add('active');
                        currentPeriod = btn.getAttribute('data-period');
                        fetchTopStats(currentPeriod);
                    });
                });
            }

            window.addEventListener('load', () => {
                const content = document.getElementById('app-content');
                if (content) content.classList.add('start-sequence');
                
                fetchLiveTrack();
                fetchTopStats(currentPeriod);
                setupPeriodControls();
                setInterval(fetchLiveTrack, 15000);
            });

// Ziyaretçi Defteri Sayfalama Mantığı
let currentPage = 1;
const messagesPerPage = 5;

// Örnek mesajları tamamen sildik (localStorage'dan veri yoksa boş liste başlar)
const savedMessages = localStorage.getItem('guestbook_messages');
let allMessages = savedMessages ? JSON.parse(savedMessages) : [];

const guestbookForm = document.getElementById('guestbook-form');
const nameInput = document.getElementById('guest-name');
const messageInput = document.getElementById('guest-message');

const prevBtn = document.getElementById('prev-messages');
const nextBtn = document.getElementById('next-messages');
const pageInfo = document.getElementById('page-info');
const messagesContainer = document.getElementById('guestbook-messages');

function renderMessages() {
    const totalPages = Math.ceil(allMessages.length / messagesPerPage) || 1;
    if (currentPage > totalPages) currentPage = totalPages;
    if (currentPage < 1) currentPage = 1;

    // En yeni mesajı en üstte göstermek için listeyi ters çevirip keselim
    const reversedMessages = [...allMessages].reverse(); 
    const startIndex = (currentPage - 1) * messagesPerPage;
    const endIndex = startIndex + messagesPerPage;
    const currentMessages = reversedMessages.slice(startIndex, endIndex);

    // Kapsayıcıyı temizle
    messagesContainer.innerHTML = '';

    if (currentMessages.length === 0) {
        // Hiç not yoksa senin istediğin mesajı basıyoruz (Mevcut 'Inter' fontuyla)
        messagesContainer.innerHTML = '<p class="msg-text muted-text" style="font-family: JetBrains Mono, monospace; font-size: 0.9rem;">Şuan hiç not bırakılmamış...</p>';
    } else {
        currentMessages.forEach(msg => {
            const messageRow = document.createElement('div');
            messageRow.className = 'message-row';
            messageRow.innerHTML = `
                <div class="message-meta">
                    <span class="msg-author">${msg.name}</span>
                    <span class="msg-time">${msg.time}</span>
                </div>
                <p class="msg-text">${msg.message}</p>
            `;
            messagesContainer.appendChild(messageRow);
        });
    }

    // Butonları ve sayfa bilgisini güncelle
    prevBtn.disabled = currentPage === 1;
    nextBtn.disabled = currentPage === totalPages;
    pageInfo.textContent = `${currentPage} / ${totalPages}`;
}

// MESAJ GÖNDERMEK VE LOCALSTORAGE'A KAYDETMEK (Sayfa Yenilenmesini Çözer)
if (guestbookForm && nameInput && messageInput) {
    guestbookForm.addEventListener('submit', (e) => {
        // Sunucuya form göndermesini tamamen engellemek için submit olayını durduruyoruz
        e.preventDefault(); 
        
        const nameValue = nameInput.value.trim();
        const messageValue = messageInput.value.trim();

        if (!nameValue || !messageValue) return;

        const now = new Date();
        const timeString = now.toLocaleTimeString('tr-TR', { hour: '2-digit', minute: '2-digit' });

        // Yeni mesajı diziye ekle
        allMessages.push({
            name: nameValue,
            time: timeString, // Veya "Az önce" diyebiliriz
            message: messageValue
        });

        // Güncellenmiş diziyi localStorage'a kaydet (KALICILIK SAĞLAYAN KISIM)
        localStorage.setItem('guestbook_messages', JSON.stringify(allMessages));

        // Formu temizle
        nameInput.value = '';
        messageInput.value = '';

        // Listenin en başına dön ve yeniden render et
        currentPage = 1;
        renderMessages();
    });
}

// Navigasyon Butonları
if (prevBtn && nextBtn) {
    prevBtn.addEventListener('click', (e) => {
        e.preventDefault(); // Varsayılan buton davranışını engelle
        currentPage--;
        renderMessages();
    });

    nextBtn.addEventListener('click', (e) => {
        e.preventDefault(); // Varsayılan buton davranışını engelle
        currentPage++;
        renderMessages();
    });
}

// Sayfa yüklendiğinde ilk render
renderMessages();
        </script>
    </body>
</html>

