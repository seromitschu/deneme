---
// src/pages/index.astro
// TERTEMİZ: API sorguları, fetch, request.url veya döngü yok.
// Sadece bileşenlerin orkestrasyonu.

import Layout from '../layouts/Layout.astro';
import Intro from '../components/Intro.astro';
import About from '../components/About.astro';

import Experience from '../components/Experience.astro';
import MusicRoom from '../components/MusicRoom.astro';
import Footer from '../components/Footer.astro';

const name = import.meta.env.PUBLIC_NAME;
const LINKS = {
  GITHUB: import.meta.env.LINK_GITHUB,
  SPOTIFY: import.meta.env.LINK_SPOTIFY,
  LINKEDIN: import.meta.env.LINK_LINKEDIN,
  DISCORD: import.meta.env.LINK_DISCORD
};
---

<Layout title={name}>
    <div id="ambient-glow" class="ambient-glow"></div>

    <div id="app-content">
        <main class="minimal-container">
            <div class="word delay-1"><Intro name={name} /></div>
            <div class="word delay-2"><About /></div>
            
            <div class="word delay-4"><Experience /></div>
            <div class="word delay-5"><MusicRoom /></div>
            <div class="word delay-6"><Footer name={name} links={LINKS} /></div>
        </main>
    </div>
</Layout>

<script>
    window.addEventListener('load', () => {
        document.getElementById('app-content')?.classList.add('start-sequence');
    });
</script>

<style>
    .minimal-container {
        max-width: 840px;
        width: 100%;
        margin: 0 auto;
        padding: clamp(2rem, 5vw, 3.5rem) clamp(1.2rem, 5vw, 1.5rem);
        display: flex;
        flex-direction: column;
        gap: 2.5rem;
    }

    .word {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.8s ease, transform 0.8s ease;
    }
    
    :global(.start-sequence .word) {
        opacity: 1;
        transform: translateY(0);
    }
    
    .delay-1 { transition-delay: 0.1s; }
    .delay-2 { transition-delay: 0.2s; }
    .delay-3 { transition-delay: 0.3s; }
    .delay-4 { transition-delay: 0.4s; }
    .delay-5 { transition-delay: 0.5s; }
    .delay-6 { transition-delay: 0.6s; }
</style>