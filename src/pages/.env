# .env (Templat'i)

# --- PORTFOLYO ANA BİLGİLERİ ---
PUBLIC_NAME=seromitschu

# --- GÜVENLİK ---
# Bu anahtarı kimseyle paylaşmayın ve .env.local gibi güvenli bir yerde saklayın.
# Vercel/Supabase gibi bir API katmanı kullanacaksanız buraya ekleyin.
# API_SECRET_KEY=yoursecretkey

# --- SOSYAL MEDYA LİNKLERİ ---
LINK_GITHUB=https://github.com/seromitschu
LINK_SPOTIFY=https://open.spotify.com/user/seromitschu
LINK_LINKEDIN=https://linkedin.com/in/seromitschu
LINK_DISCORD=https://discord.com/users/seromitschu

# --- LAST.FM API ---
# Tarayıcı tarafında çalışacaksa PUBLIC_ ön eki eklenmelidir.
PUBLIC_LASTFM_API_KEY=fa70536a9be667662278e223ac3b3d29
PUBLIC_LASTFM_USERNAME=serooooooooooo

# --- SPOTIFY API (Sunucu Tarafı) ---
# Bu anahtarlar tarayıcıya asla sızmamalıdır (PUBLIC_ ön eki OLMAYACAK).
SPOTIFY_CLIENT_ID=0c918b0ede8f4ddebb17b7d0a0bd2f8f
SPOTIFY_CLIENT_SECRET=0e0caa044a3f4a1a8cadac29238fe0b2

# --- GUESTBOOK / BLOG (İlerisi için) ---
# SUPABASE_URL=https://your-supabase-url.supabase.co
# SUPABASE_ANON_KEY=your-supabase-anon-key
